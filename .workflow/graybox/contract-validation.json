      "notes": "All top-level keys present. camelCase mapping correct (nama_pasien -> name, rekam_medis_id -> recordId)."
    },
    {
      "id": "GB-CONTRACT-03",
      "endpoint": "POST /api/transactions/pay",
      "fe_type": "{transaction:Transaction, receipt, cashLedger}",
      "status": "PASS",
      "assertions": [
        "transaction: {id,patient,therapist,status,subtotal,discount,paymentMethod,total,commission,time}",
        "receipt: {id,transactionId,subtotal,discount,paymentMethod,total}",
        "cashLedger: {type,amount,transactionId}"
      ],
      "notes": "All required keys present. Status code 201 on success."
    },
    {
      "id": "GB-CONTRACT-04",
      "endpoint": "POST /api/patients/{id}/treatments",
      "fe_type": "TreatmentNote",
      "status": "PASS",
      "assertions": ["id:int", "date:string", "therapist:string", "title:string", "notes:string"],
      "notes": "Returns full note shape. Therapist name is server-derived (F-005 fix)."
    },
    {
      "id": "GB-CONTRACT-05",
      "endpoint": "POST /api/patients/{id}/photos",
      "fe_type": "ClinicalPhoto",
      "status": "PASS",
      "assertions": ["id:string", "label:'Before'|'After'", "date:string", "objectRef:string"],
      "notes": "id is stringified per FE type. objectRef starts with 'clinical/'. Content must be data: URL or raw bytes; controller decodes and validates with getimagesizefromstring."
    },
    {
      "id": "GB-CONTRACT-06",
      "endpoint": "POST /api/inventory/purchases",
      "fe_type": "InventoryProduct",
      "status": "PASS",
      "assertions": [
        "id, name, category, totalStock, newBatch",
        "newBatch: {code, qty, hpp, expiry, supplier}"
      ],
      "notes": "Returns updated product with new batch. expiry is Y-m-d or 'Reusable' for null."
    }
