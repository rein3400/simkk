# SIM-KK production .env template
# Copy to apps/api/.env on VPS, fill real values, run: php artisan key:generate

APP_NAME="SIM-KK"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Makassar
APP_URL=https://api.sim-kk.example.id

# Frontend (Cloudflare Pages URL)
FRONTEND_URL=https://sim-kk.example.id

# Database (SQLite on VPS)
DB_CONNECTION=sqlite
# DB file is created automatically at database/database.sqlite on first migrate

# Sanctum (CORS)
SANCTUM_STATEFUL_DOMAINS=sim-kk.example.id,www.sim-kk.example.id
SESSION_DOMAIN=.sim-kk.example.id

# Cloudflare R2 (clinical photos)
STORAGE_DISK=r2
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=simkk-clinical
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_REGION=auto
R2_USE_PATH_STYLE_ENDPOINT=true

# Telegram Bot API (untuk notifikasi pasien)
# Buat bot via @BotFather, copy token ke sini
# https://core.telegram.org/bots/api
TELEGRAM_BOT_TOKEN=

# Clinic branding (untuk PDF KOP)
CLINIC_NAME="KLINIK KECANTIKAN SIM-KK"
CLINIC_ADDRESS="Jl. Klinik No. 1, Samarinda"

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=warning
